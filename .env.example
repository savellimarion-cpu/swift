# Base de données Postgres (ex. un projet gratuit sur https://neon.tech)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Clé API Anthropic — utilisée pour TOUTES les générations IA (texte +
# briefs d'images).
# Récupère-la sur https://console.anthropic.com
ANTHROPIC_API_KEY=

# Clé API OpenAI — utilisée par Romy (Designer) pour générer les visuels
# (gpt-image-1). Récupère-la sur https://platform.openai.com/api-keys
# Nécessite un compte avec accès à gpt-image-1 (vérification d'organisation
# parfois requise — voir section "Coûts à anticiper" du README).
OPENAI_API_KEY=
